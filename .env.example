# Immediate FLUX path: Pollinations cloud wrapper via the existing command adapter.
# The wrapper uses the legacy Pollinations endpoint in anonymous mode and switches to the
# unified endpoint first when VIDEO_STUDIO_POLLINATIONS_API_KEY is provided manually.
VIDEO_STUDIO_FLUX_MODE=command
VIDEO_STUDIO_FLUX_COMMAND=["{project_root}/.venv/Scripts/python.exe","{project_root}/scripts/pollinations_flux.py","--prompt-path","{prompt_path}","--output-path","{output_path}","--timeout-sec","45","--max-attempts","4","--endpoint-mode","auto","--min-request-gap-sec","90","--initial-backoff-sec","8","--backoff-jitter-sec","4","--max-backoff-sec","45"]

# Keep Wan in stub mode until a local video runner is ready on this machine.
VIDEO_STUDIO_WAN_MODE=stub

# Adapter subprocess timeout in seconds.
VIDEO_STUDIO_MEDIA_TIMEOUT_SEC=360

# Optional Pollinations auth + retry tuning.
# Leave the API key blank for anonymous use, or set a backend/server key manually on the machine.
# The wrapper forwards it as an Authorization Bearer header and does not place it in command logs.
VIDEO_STUDIO_POLLINATIONS_API_KEY=
VIDEO_STUDIO_POLLINATIONS_MAX_ATTEMPTS=4
VIDEO_STUDIO_POLLINATIONS_ENDPOINT_MODE=auto
VIDEO_STUDIO_POLLINATIONS_MIN_REQUEST_GAP_SEC=90
VIDEO_STUDIO_POLLINATIONS_INITIAL_BACKOFF_SEC=8
VIDEO_STUDIO_POLLINATIONS_BACKOFF_JITTER_SEC=4
VIDEO_STUDIO_POLLINATIONS_MAX_BACKOFF_SEC=45

# Local FLUX alternative after gated weights are fully downloaded and stable:
# VIDEO_STUDIO_FLUX_MODE=command
# VIDEO_STUDIO_FLUX_COMMAND=["C:/path/to/python.exe","C:/path/to/run_flux.py","--job-path","{job_path}"]

# ===== Pollinations image provider (default free image path) =====
# Pollinations is auto-enabled as the default image provider.
# Set mode to "command" to use it explicitly through the adapter system.
VIDEO_STUDIO_POLLINATIONS_MODE=command
VIDEO_STUDIO_POLLINATIONS_COMMAND=["{project_root}/.venv/Scripts/python.exe","{project_root}/scripts/pollinations_flux.py","--prompt-path","{prompt_path}","--output-path","{output_path}","--timeout-sec","45","--max-attempts","4"]

# ===== Edge TTS (free cross-platform TTS — default voice provider) =====
# Requires: pip install edge-tts
VIDEO_STUDIO_EDGE_TTS_MODE=command
VIDEO_STUDIO_EDGE_TTS_COMMAND=["{project_root}/.venv/Scripts/python.exe","{project_root}/scripts/edge_tts.py","--prompt-path","{prompt_path}","--output-path","{output_path}"]
# VIDEO_STUDIO_EDGE_TTS_VOICE=ko-KR-SunHiNeural
# VIDEO_STUDIO_EDGE_TTS_RATE=+0%

# ===== Local BGM library =====
# BGM tracks in assets/bgm/ are selected by mood or at random.
VIDEO_STUDIO_LOCAL_BGM_MODE=stub

