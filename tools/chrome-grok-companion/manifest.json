{
  "manifest_version": 3,
  "name": "Video Studio AI Web Companion",
  "version": "0.1.0",
  "description": "Operator-approved Grok and Gemini web handoff helper for an existing signed-in Chrome profile.",
  "permissions": [
    "activeTab",
    "alarms",
    "downloads",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:5161/*",
    "https://gemini.google.com/*",
    "https://gemini.google-b197145817.com/*",
    "https://grok.com/*",
    "https://*.grok.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://grok.com/*",
        "https://*.grok.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://gemini.google-b197145817.com/*"
      ],
      "js": [
        "content_gemini.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Video Studio AI Web Companion",
    "default_popup": "popup.html"
  }
}
