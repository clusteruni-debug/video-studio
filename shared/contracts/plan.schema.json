{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://video-studio.local/contracts/project-plan.schema.json",
    "title": "ProjectPlan",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "version",
        "title",
        "sourcePrompt",
        "aspectRatio",
        "budgetMode",
        "monthlyCapUsd",
        "scenes"
    ],
    "properties": {
        "version": {
            "const": 1
        },
        "title": {
            "type": "string",
            "minLength": 1
        },
        "sourcePrompt": {
            "type": "string",
            "minLength": 1
        },
        "aspectRatio": {
            "enum": ["9:16"]
        },
        "budgetMode": {
            "enum": ["free", "standard", "premium"]
        },
        "monthlyCapUsd": {
            "type": "number",
            "minimum": 0
        },
        "scenes": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/sceneSpec"
            }
        }
    },
    "$defs": {
        "sceneSpec": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "id",
                "title",
                "prompt",
                "durationSec",
                "priority",
                "humanRealism",
                "nativeAudioNeed",
                "canUseStillImage",
                "subtitleText",
                "routeHint"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "minLength": 1
                },
                "title": {
                    "type": "string",
                    "minLength": 1
                },
                "prompt": {
                    "type": "string",
                    "minLength": 1
                },
                "durationSec": {
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "priority": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5
                },
                "humanRealism": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5
                },
                "nativeAudioNeed": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 5
                },
                "canUseStillImage": {
                    "type": "boolean"
                },
                "subtitleText": {
                    "type": "string"
                },
                "routeHint": {
                    "enum": ["local", "veo3"]
                }
            }
        }
    }
}
